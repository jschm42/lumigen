generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model StorageTemplate {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  baseDir   String    @map("base_dir")
  template  String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  profiles  Profile[]

  @@map("storage_templates")
}

model ModelConfig {
  id              Int       @id @default(autoincrement())
  name            String    @unique
  provider        String
  model           String
  enhancementPrompt String? @map("enhancement_prompt")
  apiKeyEncrypted String?   @map("api_key_encrypted")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  profiles        Profile[]

  @@map("model_configs")
}

model Profile {
  id                Int             @id @default(autoincrement())
  name              String          @unique
  provider          String
  model             String
  modelConfigId     Int?            @map("model_config_id")
  modelConfig       ModelConfig?    @relation(fields: [modelConfigId], references: [id], onDelete: SetNull)
  basePrompt        String?         @map("base_prompt")
  negativePrompt    String?         @map("negative_prompt")
  width             Int?
  height            Int?
  aspectRatio       String?         @map("aspect_ratio")
  nImages           Int             @map("n_images")
  seed              Int?
  outputFormat      String          @map("output_format")
  paramsJson        String          @map("params_json")
  storageTemplateId Int             @map("storage_template_id")
  storageTemplate   StorageTemplate @relation(fields: [storageTemplateId], references: [id], onDelete: Restrict)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  generations       Generation[]

  @@map("profiles")
}

model GalleryFolder {
  id        Int      @id @default(autoincrement())
  path      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  assets    Asset[]

  @@map("gallery_folders")
}

model EnhancementConfig {
  id              Int       @id @default(autoincrement())
  provider        String
  model           String
  apiKeyEncrypted String?   @map("api_key_encrypted")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("enhancement_configs")
}

model DimensionPreset {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  width     Int
  height    Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dimension_presets")
}

model Generation {
  id                         Int       @id @default(autoincrement())
  profileId                  Int?      @map("profile_id")
  profile                    Profile?  @relation(fields: [profileId], references: [id], onDelete: SetNull)
  profileName                String    @map("profile_name")
  promptUser                 String    @map("prompt_user")
  promptFinal                String    @map("prompt_final")
  provider                   String
  model                      String
  status                     String
  error                      String?
  profileSnapshotJson        String    @map("profile_snapshot_json")
  storageTemplateSnapshotJson String   @map("storage_template_snapshot_json")
  requestSnapshotJson        String    @map("request_snapshot_json")
  failureSidecarPath         String?   @map("failure_sidecar_path")
  createdAt                  DateTime  @default(now()) @map("created_at")
  finishedAt                 DateTime? @map("finished_at")
  assets                     Asset[]

  @@map("generations")
}

model Asset {
  id             Int           @id @default(autoincrement())
  generationId   Int           @map("generation_id")
  generation     Generation    @relation(fields: [generationId], references: [id], onDelete: Cascade)
  galleryFolderId Int?         @map("gallery_folder_id")
  galleryFolder  GalleryFolder? @relation(fields: [galleryFolderId], references: [id], onDelete: SetNull)
  filePath       String        @unique @map("file_path")
  sidecarPath    String        @map("sidecar_path")
  thumbnailPath  String        @map("thumbnail_path")
  width          Int
  height         Int
  mime           String
  metaJson       String        @map("meta_json")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@map("assets")
}
