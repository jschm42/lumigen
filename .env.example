PROVIDER_STUB_MAX_CONCURRENT=4
PROVIDER_STUB_MIN_INTERVAL_MS=50

PROVIDER_OPENAI_MAX_CONCURRENT=1
PROVIDER_OPENAI_MIN_INTERVAL_MS=800
OPENAI_API_KEY=
