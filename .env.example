APP_NAME=img-hub
SQLITE_PATH=./data/app.db
DEFAULT_BASE_DIR=./data/images
DEFAULT_STORAGE_TEMPLATE=/{profile}/{yyyy}/{mm}/{slug}-{gen_id}-{idx}.{ext}

